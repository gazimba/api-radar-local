// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Cargo {
  COMUM
  ADMINISTRADOR
}

enum Status {
  PENDENTE
  APROVADO
  REJEITADO
}

model User {
  id    Int    @id @default(autoincrement())
  email String @unique
  nome  String
  senha String
  cargo Cargo  @default(COMUM)

  createdAt DateTime @default(now())
}

model PontoTuristico {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String
  informacoes String
  destaques   String
  latitude    Float
  longitude   Float
  status      Status @default(PENDENTE)
  createdAt   DateTime @default(now())

}

model Evento {
  id          Int      @id @default(autoincrement())
  nome        String
  descricao   String
  data        DateTime
  horario     String
  informacoes String
  latitude    Float
  longitude   Float
  status      Status @default(PENDENTE)
  createdAt   DateTime @default(now())
}
